{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sastbench.dev/schema/case.schema.json",
  "title": "SASTbench Case Definition",
  "description": "Schema for a SASTbench benchmark case with region-level annotations",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "track",
    "caseType",
    "language",
    "canonicalKind",
    "files",
    "regions",
    "expectedOutcome"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version for this case definition"
    },
    "id": {
      "type": "string",
      "pattern": "^SB-[A-Z]{2}-[A-Z]{2,3}-[0-9]{3}$",
      "description": "Unique case identifier, e.g. SB-PY-SV-001"
    },
    "track": {
      "type": "string",
      "enum": ["core", "full"],
      "description": "Benchmark track this case belongs to"
    },
    "caseType": {
      "type": "string",
      "enum": [
        "synthetic_vulnerable",
        "capability_safe",
        "mixed_intent",
        "real_world_disclosed"
      ],
      "description": "The type of benchmark case"
    },
    "language": {
      "type": "string",
      "enum": ["python", "typescript", "rust", "swift"],
      "description": "Primary language of the case"
    },
    "canonicalKind": {
      "type": "string",
      "enum": ["command_injection", "path_traversal", "ssrf", "auth_bypass", "authz_bypass", "sql_injection"],
      "description": "The primary canonical vulnerability kind"
    },
    "title": {
      "type": "string",
      "description": "Short human-readable title for the case"
    },
    "description": {
      "type": "string",
      "description": "One-paragraph description of the case scenario"
    },
    "files": {
      "type": "object",
      "required": ["root"],
      "properties": {
        "root": {
          "type": "string",
          "description": "Relative path to the scannable project root"
        }
      },
      "additionalProperties": false
    },
    "regions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/region"
      },
      "description": "Annotated regions within the case"
    },
    "expectedOutcome": {
      "type": "object",
      "required": ["mustDetectRegionIds"],
      "properties": {
        "mustDetectRegionIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Region IDs that scanners must flag as vulnerable"
        },
        "mustNotFlagRegionIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Region IDs that scanners must not flag"
        }
      },
      "additionalProperties": false
    },
    "realWorld": {
      "$ref": "#/$defs/realWorldMeta",
      "description": "Metadata for real_world_disclosed cases"
    },
    "prSimulation": {
      "$ref": "#/$defs/prSimulation",
      "description": "Optional PR simulation metadata for PR benchmark mode"
    },
    "standards": {
      "$ref": "#/$defs/standardsMappings",
      "description": "Mappings to external security standards"
    }
  },
  "additionalProperties": false,
  "if": {
    "properties": { "caseType": { "const": "real_world_disclosed" } }
  },
  "then": {
    "required": ["realWorld"]
  },
  "$defs": {
    "region": {
      "type": "object",
      "required": ["id", "path", "startLine", "endLine", "label"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique region identifier within this case"
        },
        "path": {
          "type": "string",
          "description": "Path to the file relative to files.root (scan_root)"
        },
        "startLine": {
          "type": "integer",
          "minimum": 1,
          "description": "First line of the annotated region (1-indexed)"
        },
        "endLine": {
          "type": "integer",
          "minimum": 1,
          "description": "Last line of the annotated region (1-indexed)"
        },
        "label": {
          "type": "string",
          "enum": ["vulnerable", "capability_safe"],
          "description": "Whether this region is vulnerable or intentionally safe"
        },
        "capability": {
          "type": "string",
          "enum": ["code_execution", "filesystem", "network", "authentication", "authorization", "data_store"],
          "description": "The capability family exercised by this region"
        },
        "acceptedKinds": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["command_injection", "path_traversal", "ssrf", "auth_bypass", "authz_bypass", "sql_injection"]
          },
          "description": "Canonical kinds that count as a match for this region"
        },
        "requiredGuards": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "allowlist",
              "workspace_root",
              "host_allowlist",
              "scheme_allowlist",
              "caller_verification",
              "secret_validation",
              "scope_binding",
              "role_check",
              "parameterized_query"
            ]
          },
          "description": "Guard contracts that make a capability_safe region safe"
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "label": { "const": "capability_safe" } } },
          "then": { "required": ["requiredGuards", "capability"] }
        },
        {
          "if": { "properties": { "label": { "const": "vulnerable" } } },
          "then": { "required": ["acceptedKinds"] }
        }
      ]
    },
    "realWorldMeta": {
      "type": "object",
      "required": ["repo", "vulnerableCommit", "fixCommit"],
      "properties": {
        "repo": {
          "type": "string",
          "description": "GitHub repo in owner/name format"
        },
        "vulnerableCommit": {
          "type": "string",
          "description": "Git commit SHA of the vulnerable snapshot"
        },
        "fixCommit": {
          "type": "string",
          "description": "Git commit SHA of the fix"
        },
        "ghsa": {
          "type": "string",
          "pattern": "^GHSA-",
          "description": "GitHub Security Advisory ID"
        },
        "cve": {
          "type": "string",
          "pattern": "^CVE-",
          "description": "CVE identifier if available"
        }
      },
      "additionalProperties": false
    },
    "standardsMappings": {
      "type": "object",
      "properties": {
        "owaspAgenticTop10": {
          "$ref": "#/$defs/owaspAgenticTop10"
        }
      },
      "additionalProperties": false
    },
    "owaspAgenticTop10": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary": {
          "type": "string",
          "pattern": "^ASI(0[1-9]|10)$",
          "description": "Primary OWASP Agentic Top 10 category"
        },
        "secondary": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^ASI(0[1-9]|10)$"
          },
          "description": "Secondary OWASP Agentic Top 10 categories"
        }
      },
      "additionalProperties": false
    },
    "fixValidation": {
      "type": "object",
      "description": "How to verify that fixCommit addresses the vulnerability. Default (or omitted) is slice_absent: fix must remove the annotated vulnerable slice. For indirect mitigations where the fix lands outside the annotated sink, use mitigation_anchor_present.",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["slice_absent", "mitigation_anchor_present"],
          "description": "slice_absent: fix must not contain the vulnerable slice. mitigation_anchor_present: fix must contain declared anchor strings that the vulnerable commit does not."
        },
        "anchors": {
          "type": "array",
          "description": "Anchor checks for mitigation_anchor_present mode.",
          "items": {
            "type": "object",
            "required": ["path", "mustContainAll"],
            "properties": {
              "path": {
                "type": "string",
                "description": "File path relative to the repo root."
              },
              "mustContainAll": {
                "type": "array",
                "items": { "type": "string" },
                "description": "All listed strings must appear in the file at fixCommit."
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "mode": { "const": "mitigation_anchor_present" } } },
          "then": { "required": ["anchors"] }
        }
      ]
    },
    "prSimulation": {
      "type": "object",
      "required": ["mode"],
      "description": "PR simulation metadata. Defines how to construct base and head trees for PR benchmark mode.",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["vendored_base", "git_commit_pair"],
          "description": "How the clean baseline is provided: vendored_base uses a pr/base/ directory, git_commit_pair uses explicit commit SHAs"
        },
        "baseRoot": {
          "type": "string",
          "description": "Relative path (from case dir) to the clean baseline tree. Required for vendored_base mode."
        },
        "baseCommit": {
          "type": "string",
          "description": "Git commit SHA of the clean baseline state. Required for git_commit_pair mode."
        },
        "headCommit": {
          "type": "string",
          "description": "Git commit SHA of the vulnerable head state. Optional for git_commit_pair mode; defaults to realWorld.vulnerableCommit."
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "mode": { "const": "vendored_base" } } },
          "then": { "required": ["baseRoot"] }
        },
        {
          "if": { "properties": { "mode": { "const": "git_commit_pair" } } },
          "then": { "required": ["baseCommit"] }
        }
      ]
    }
  }
}
