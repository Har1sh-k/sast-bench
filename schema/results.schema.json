{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sastbench.dev/schema/results.schema.json",
  "title": "SASTbench Results",
  "description": "Schema for normalized scanner results from a SASTbench run",
  "type": "object",
  "required": [
    "schemaVersion",
    "benchmarkVersion",
    "mode",
    "scanner",
    "track",
    "timestamp",
    "caseResults",
    "summary"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "benchmarkVersion": {
      "type": "string",
      "description": "SASTbench version used for this run"
    },
    "mode": {
      "type": "string",
      "enum": ["benchmark", "pr"],
      "description": "Execution mode: benchmark (standard) or pr (PR simulation)"
    },
    "scanner": {
      "type": "object",
      "required": ["name", "version", "adapter"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Scanner name, e.g. semgrep"
        },
        "version": {
          "type": "string",
          "description": "Scanner version string"
        },
        "adapter": {
          "type": "string",
          "description": "Adapter version used for normalization"
        }
      },
      "additionalProperties": false
    },
    "track": {
      "type": "string",
      "enum": ["core", "full"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the run"
    },
    "caseResults": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/caseResult"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "prSummary": {
      "$ref": "#/$defs/prSummary",
      "description": "Aggregate PR-mode metrics (present only in pr mode results)"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "caseResult": {
      "type": "object",
      "required": ["caseId", "caseTrack", "caseType", "language", "findings", "scoring", "artifacts"],
      "properties": {
        "caseId": {
          "type": "string",
          "description": "The benchmark case ID"
        },
        "caseTrack": {
          "type": "string",
          "enum": ["core", "full"],
          "description": "Track the case belongs to"
        },
        "caseType": {
          "type": "string",
          "enum": ["synthetic_vulnerable", "capability_safe", "mixed_intent", "real_world_disclosed"],
          "description": "Case type for reporting and aggregation"
        },
        "language": {
          "type": "string",
          "enum": ["python", "typescript", "rust", "swift"],
          "description": "Primary language of the case"
        },
        "findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          }
        },
        "scoring": {
          "$ref": "#/$defs/caseScoring"
        },
        "artifacts": {
          "$ref": "#/$defs/artifacts"
        },
        "prContext": {
          "$ref": "#/$defs/prContext",
          "description": "PR simulation context (present only in pr mode results)"
        },
        "prScoring": {
          "$ref": "#/$defs/prScoring",
          "description": "PR-specific scoring (present only in pr mode results)"
        }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "object",
      "required": ["commandInvocation", "exitCode", "rawStdoutPath", "rawStderrPath", "skipReason"],
      "properties": {
        "commandInvocation": {
          "type": ["array", "null"],
          "items": { "type": "string" },
          "description": "Exact scanner command used for this case"
        },
        "exitCode": {
          "type": ["integer", "null"],
          "description": "Scanner process exit code, if one was produced"
        },
        "rawStdoutPath": {
          "type": ["string", "null"],
          "description": "Path to raw stdout relative to the results JSON directory"
        },
        "rawStderrPath": {
          "type": ["string", "null"],
          "description": "Path to raw stderr relative to the results JSON directory"
        },
        "skipReason": {
          "type": ["string", "null"],
          "description": "Reason the adapter did not run this case, if applicable"
        }
      },
      "additionalProperties": false
    },
    "finding": {
      "type": "object",
      "required": ["ruleId", "mappedKind", "path", "startLine", "endLine"],
      "properties": {
        "ruleId": {
          "type": "string",
          "description": "Original rule ID from the scanner"
        },
        "mappedKind": {
          "type": "string",
          "enum": ["command_injection", "path_traversal", "ssrf", "auth_bypass", "authz_bypass", "sql_injection", "unmapped"],
          "description": "Canonical kind this finding maps to"
        },
        "path": {
          "type": "string",
          "description": "File path relative to scan_root (files.root)"
        },
        "startLine": {
          "type": "integer",
          "minimum": 1
        },
        "endLine": {
          "type": "integer",
          "minimum": 1
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "description": "Scanner-reported severity (display only, not scored)"
        },
        "message": {
          "type": "string",
          "description": "Scanner-reported message"
        },
        "matchedRegionId": {
          "type": ["string", "null"],
          "description": "Region ID this finding overlaps with, if any"
        },
        "classification": {
          "type": "string",
          "enum": [
            "true_positive",
            "capability_false_positive",
            "false_positive",
            "unmatched"
          ],
          "description": "Benchmark classification of this finding"
        }
      },
      "additionalProperties": false
    },
    "caseScoring": {
      "type": "object",
      "required": ["truePositives", "falseNegatives", "capabilityFalsePositives"],
      "properties": {
        "truePositives": {
          "type": "integer",
          "minimum": 0
        },
        "falseNegatives": {
          "type": "integer",
          "minimum": 0
        },
        "falsePositives": {
          "type": "integer",
          "minimum": 0
        },
        "capabilityFalsePositives": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "prContext": {
      "type": "object",
      "required": ["changedFiles", "baselineFindings", "headFindings", "reviewFindings"],
      "properties": {
        "changedFiles": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Files changed between base and head"
        },
        "baselineFindings": {
          "type": "array",
          "items": { "$ref": "#/$defs/finding" },
          "description": "Findings from scanning the clean base tree"
        },
        "headFindings": {
          "type": "array",
          "items": { "$ref": "#/$defs/finding" },
          "description": "Findings from scanning the vulnerable head tree"
        },
        "reviewFindings": {
          "type": "array",
          "items": { "$ref": "#/$defs/finding" },
          "description": "New-in-head findings (review findings)"
        }
      },
      "additionalProperties": false
    },
    "prScoring": {
      "type": "object",
      "required": [
        "introducedTargetsDetected",
        "introducedTargetsTotal",
        "introducedTargetHitRate",
        "reviewNoise",
        "capabilityNoise"
      ],
      "properties": {
        "introducedTargetsDetected": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of mustDetectRegionIds hit by reviewFindings"
        },
        "introducedTargetsTotal": {
          "type": "integer",
          "minimum": 0,
          "description": "Total mustDetectRegionIds for this case"
        },
        "introducedTargetHitRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "introducedTargetsDetected / introducedTargetsTotal"
        },
        "reviewNoise": {
          "type": "integer",
          "minimum": 0,
          "description": "Review findings that did not match any introduced target"
        },
        "capabilityNoise": {
          "type": "integer",
          "minimum": 0,
          "description": "Review findings that matched a capability_safe region"
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "recall",
        "precision",
        "capabilityFpRate",
        "mixedIntentAccuracy",
        "agenticScore"
      ],
      "properties": {
        "recall": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "precision": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "capabilityFpRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "mixedIntentAccuracy": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "agenticScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "geometric_mean(recall, 1 - capabilityFpRate, mixedIntentAccuracy)"
        }
      },
      "additionalProperties": false
    },
    "prSummary": {
      "type": "object",
      "required": [
        "introducedTargetHitRate",
        "totalReviewNoise",
        "totalCapabilityNoise",
        "casesEvaluated",
        "casesSkipped"
      ],
      "properties": {
        "introducedTargetHitRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Aggregate introduced target detection rate across all PR cases"
        },
        "totalReviewNoise": {
          "type": "integer",
          "minimum": 0,
          "description": "Total review findings that did not match introduced targets"
        },
        "totalCapabilityNoise": {
          "type": "integer",
          "minimum": 0,
          "description": "Total review findings that matched capability_safe regions"
        },
        "casesEvaluated": {
          "type": "integer",
          "minimum": 0
        },
        "casesSkipped": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  }
}
